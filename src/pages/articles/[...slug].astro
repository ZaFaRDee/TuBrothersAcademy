---
import { getCollection, render } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import Container from "~/components/ui/Container.astro";
import { SITE } from "~/data/site";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const all = (await getCollection("articles")).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
const idx = all.findIndex((a) => a.id === article.id);
const prev = all[idx + 1];
const next = all[idx - 1];

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---

<BaseLayout
  title={article.data.title}
  description={article.data.excerpt}
  type="article"
  publishedTime={article.data.publishedAt.toISOString()}
>
  <article>
    <section class="relative isolate overflow-hidden bg-ink-950 text-white pt-32 pb-16 md:pt-40 md:pb-24">
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
        <div class="absolute -top-32 -left-24 size-[480px] rounded-full bg-brand-700/40 blur-[120px] animate-blob"></div>
        <div class="absolute -bottom-32 -right-32 size-[520px] rounded-full bg-brand-500/30 blur-[120px] animate-blob" style="animation-delay: -8s;"></div>
      </div>
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 grid-pattern opacity-15 mask-fade-b"></div>

      <Container class="relative">
        <a href="/articles" class="anim-on-scroll inline-flex items-center gap-2 text-sm font-semibold text-white/70 hover:text-white mb-6 group">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" class="size-4 transition-transform group-hover:-translate-x-1">
            <path d="M19 12H5M12 5l-7 7 7 7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          All articles
        </a>

        <div class="flex flex-wrap gap-2 mb-6 anim-on-scroll">
          {article.data.tags.map((t) => (
            <span class="inline-flex items-center px-3 py-1 rounded-full bg-white/10 border border-white/15 text-xs font-semibold uppercase tracking-wider text-white/90">
              {t}
            </span>
          ))}
        </div>

        <h1 class="anim-on-scroll delay-1 text-balance text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-display font-bold leading-[1.05] tracking-tight max-w-4xl">
          {article.data.title}
        </h1>

        <div class="anim-on-scroll delay-2 mt-8 flex flex-wrap items-center gap-4 text-sm text-white/70">
          <div class="flex items-center gap-3">
            <div class="grid place-items-center size-9 rounded-full bg-brand-600 text-white font-bold text-xs">DT</div>
            <div>
              <div class="text-white font-medium">{article.data.author}</div>
              <div class="text-white/50 text-xs">Founder · TU Brothers Academy</div>
            </div>
          </div>
          <span class="size-1 rounded-full bg-white/30"></span>
          <time datetime={article.data.publishedAt.toISOString()}>{fmt(article.data.publishedAt)}</time>
          <span class="size-1 rounded-full bg-white/30"></span>
          <span>{article.data.readingMinutes} min read</span>
        </div>
      </Container>
    </section>

    <section class="py-16 md:py-24 bg-white">
      <Container>
        <div class="anim-on-scroll mx-auto max-w-3xl text-lg leading-[1.85] text-ink-700 prose-tu">
          <Content />
        </div>

        <div class="mx-auto max-w-3xl mt-16 pt-8 border-t border-ink-100 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <span class="text-sm font-semibold text-ink-700">Share:</span>
            <a
              href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(SITE.url + "/articles/" + article.id)}&text=${encodeURIComponent(article.data.title)}`}
              target="_blank" rel="noopener"
              aria-label="Share on Twitter"
              class="grid place-items-center size-10 rounded-xl bg-ink-50 hover:bg-brand-600 hover:text-white text-ink-600 transition-colors"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" class="size-4"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231z"/></svg>
            </a>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(SITE.url + "/articles/" + article.id)}`}
              target="_blank" rel="noopener"
              aria-label="Share on LinkedIn"
              class="grid place-items-center size-10 rounded-xl bg-ink-50 hover:bg-brand-600 hover:text-white text-ink-600 transition-colors"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" class="size-4"><path d="M4.98 3.5a2.5 2.5 0 11-.02 5.001A2.5 2.5 0 014.98 3.5zM3 9h4v12H3V9zm7 0h3.8v1.7h.05c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.4c0-1.3-.02-2.97-1.8-2.97-1.8 0-2.08 1.4-2.08 2.87V21h-4V9z"/></svg>
            </a>
          </div>
          <a href="/articles" class="text-brand-700 font-semibold hover:text-brand-900 transition-colors">← Back to articles</a>
        </div>
      </Container>
    </section>

    {(prev || next) && (
      <section class="py-16 bg-ink-50">
        <Container>
          <div class="grid md:grid-cols-2 gap-5">
            {prev ? (
              <a href={`/articles/${prev.id}`} class="group block rounded-3xl bg-white p-6 ring-1 ring-ink-100 hover:ring-brand-300 hover:shadow-lg transition-all">
                <div class="text-xs uppercase tracking-wider text-ink-500 font-semibold">Previous</div>
                <div class="mt-2 font-display font-bold text-ink-900 group-hover:text-brand-700 transition-colors">{prev.data.title}</div>
              </a>
            ) : <div></div>}
            {next ? (
              <a href={`/articles/${next.id}`} class="group block rounded-3xl bg-white p-6 ring-1 ring-ink-100 hover:ring-brand-300 hover:shadow-lg transition-all md:text-right">
                <div class="text-xs uppercase tracking-wider text-ink-500 font-semibold">Next</div>
                <div class="mt-2 font-display font-bold text-ink-900 group-hover:text-brand-700 transition-colors">{next.data.title}</div>
              </a>
            ) : <div></div>}
          </div>
        </Container>
      </section>
    )}
  </article>
</BaseLayout>

<style is:global>
  .prose-tu h2 {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-ink-900);
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    line-height: 1.2;
    margin-top: 3rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  .prose-tu h3 {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-ink-900);
    font-size: 1.4rem;
    line-height: 1.25;
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
  }
  .prose-tu p { margin-block: 1.1rem; }
  .prose-tu p:first-of-type { font-size: 1.18rem; color: var(--color-ink-700); }
  .prose-tu strong { color: var(--color-ink-900); font-weight: 700; }
  .prose-tu em { color: var(--color-ink-700); }
  .prose-tu a {
    color: var(--color-brand-700);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
  }
  .prose-tu a:hover { color: var(--color-brand-900); }
  .prose-tu ul {
    margin-block: 1.25rem;
    padding-inline-start: 0;
    list-style: none;
  }
  .prose-tu ul li {
    position: relative;
    padding-inline-start: 1.75rem;
    margin-block: 0.6rem;
  }
  .prose-tu ul li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--color-brand-600);
  }
  .prose-tu blockquote {
    margin-block: 2rem;
    padding: 1.25rem 1.5rem;
    border-left: 4px solid var(--color-brand-600);
    background: var(--color-brand-50);
    border-radius: 12px;
    font-style: italic;
    color: var(--color-ink-700);
  }
  .prose-tu code {
    background: var(--color-ink-100);
    padding: 0.15rem 0.4rem;
    border-radius: 6px;
    font-size: 0.95em;
    color: var(--color-brand-800);
  }
</style>
