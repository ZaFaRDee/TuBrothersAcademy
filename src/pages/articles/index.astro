---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import PageHero from "~/components/ui/PageHero.astro";
import Container from "~/components/ui/Container.astro";

const articles = (await getCollection("articles")).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
---

<BaseLayout
  title="Articles"
  description="Long-form essays on hospitality, service, wine, and operations — from the founder of TU Brothers Academy."
>
  <PageHero
    eyebrow="Articles"
    title="Insights from the <span class='animate-shimmer'>dining room</span>."
    subtitle="Long-form thinking on the craft of service, wine, bar work, and operations — written from the floor."
  />

  <section class="py-20 md:py-28 bg-white">
    <Container>
      <div class="grid md:grid-cols-2 gap-6 md:gap-8">
        {articles.map((a, i) => (
          <a
            href={`/articles/${a.id}`}
            class="anim-on-scroll group relative flex flex-col rounded-3xl bg-white border border-ink-100 p-7 md:p-9 hover:border-brand-300 hover:shadow-xl hover:-translate-y-1 transition-all duration-500 overflow-hidden"
            style={`transition-delay: ${i * 70}ms`}
          >
            <div aria-hidden="true" class="pointer-events-none absolute -top-20 -right-20 size-48 rounded-full bg-brand-50 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

            <div class="relative flex items-center gap-2 text-xs text-ink-500 font-medium">
              <time datetime={a.data.publishedAt.toISOString()}>{fmt(a.data.publishedAt)}</time>
              <span class="size-1 rounded-full bg-ink-300"></span>
              <span>{a.data.readingMinutes} min read</span>
              {a.data.featured && (
                <>
                  <span class="size-1 rounded-full bg-ink-300"></span>
                  <span class="text-brand-700 font-semibold">Featured</span>
                </>
              )}
            </div>

            <h2 class="relative mt-4 text-2xl md:text-3xl font-display font-bold leading-snug text-ink-900 group-hover:text-brand-700 transition-colors text-balance">
              {a.data.title}
            </h2>
            <p class="relative mt-4 text-ink-500 leading-relaxed">{a.data.excerpt}</p>

            <div class="relative mt-6 pt-5 border-t border-ink-100 flex items-center justify-between">
              <div class="flex flex-wrap gap-1.5">
                {a.data.tags.map((t) => (
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full bg-brand-50 text-brand-700 text-[11px] font-semibold uppercase tracking-wider">{t}</span>
                ))}
              </div>
              <span class="text-brand-700 font-semibold text-sm transition-transform group-hover:translate-x-1">Read →</span>
            </div>
          </a>
        ))}
      </div>
    </Container>
  </section>
</BaseLayout>
