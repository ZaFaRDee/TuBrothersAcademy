---
import BaseLayout from "~/layouts/BaseLayout.astro";
import PageHero from "~/components/ui/PageHero.astro";
import Container from "~/components/ui/Container.astro";
import { COURSES } from "~/data/courses";
---

<BaseLayout
  title="Courses"
  description="Hands-on, on-demand training for waiters, sommeliers, bartenders, and operators — built by industry veterans."
>
  <PageHero
    eyebrow="Curriculum"
    title="Tracks built around <span class='animate-shimmer'>real shifts</span>."
    subtitle="From your first walk to a table to running your own room — bite-sized lessons, replayable demos, and field cheat-sheets."
  />

  <section class="py-20 md:py-28 bg-white">
    <Container>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {COURSES.map((c, i) => (
          <article
            class="anim-on-scroll group relative flex flex-col rounded-3xl bg-white p-7 md:p-8 ring-1 ring-ink-100 hover:ring-brand-300 hover:shadow-xl hover:-translate-y-1 transition-all duration-500 overflow-hidden"
            style={`transition-delay: ${i * 70}ms`}
          >
            <div aria-hidden="true" class="pointer-events-none absolute -top-20 -right-20 size-44 rounded-full bg-brand-50 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

            {c.comingSoon && (
              <div class="absolute top-5 right-5 px-2.5 py-1 rounded-full bg-ink-900 text-white text-[10px] font-bold uppercase tracking-wider">
                Coming soon
              </div>
            )}

            <div class="relative">
              <div class="flex items-center gap-2 text-xs">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full bg-brand-50 text-brand-700 font-semibold uppercase tracking-wider text-[10px]">{c.category}</span>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full bg-ink-100 text-ink-600 font-semibold uppercase tracking-wider text-[10px]">{c.level}</span>
              </div>

              <h2 class="mt-5 text-xl md:text-2xl font-display font-bold leading-snug text-ink-900 group-hover:text-brand-700 transition-colors">{c.title}</h2>
              <p class="mt-3 text-sm md:text-base text-ink-500 leading-relaxed">{c.description}</p>

              <div class="mt-5 flex flex-wrap gap-1.5">
                {c.tags.map((t) => (
                  <span class="inline-flex items-center px-2 py-0.5 rounded-md bg-ink-50 text-ink-600 text-[11px] font-medium">{t}</span>
                ))}
              </div>
            </div>

            <div class="relative mt-7 pt-5 border-t border-ink-100 flex items-center justify-between text-sm text-ink-500">
              <div class="flex items-center gap-4">
                <span class="inline-flex items-center gap-1.5">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="size-4">
                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                  </svg>
                  {c.duration}
                </span>
                <span class="inline-flex items-center gap-1.5">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="size-4">
                    <polygon points="6,4 20,12 6,20" fill="currentColor" stroke-linejoin="round"/>
                  </svg>
                  {c.lessons} lessons
                </span>
              </div>
              <a href="/contact" class="text-brand-700 font-semibold transition-transform group-hover:translate-x-1">Notify me →</a>
            </div>
          </article>
        ))}
      </div>

      <div class="anim-on-scroll mt-16 max-w-3xl mx-auto text-center">
        <p class="text-ink-500 text-lg">
          Cohorts launch throughout the year. <a href="/contact" class="text-brand-700 font-semibold hover:text-brand-900">Join the waitlist</a> to be first to know.
        </p>
      </div>
    </Container>
  </section>
</BaseLayout>
