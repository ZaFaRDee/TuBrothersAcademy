---
import { Image } from "astro:assets";
import { SITE } from "~/data/site";
import logoLight from "~/assets/logo-light.png";

const year = new Date().getFullYear();

const learn = [
  { label: "Courses", href: "/courses" },
  { label: "Articles", href: "/articles" },
  { label: "Pricing", href: "/#pricing" },
];

const company = [
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
  { label: "Privacy", href: "/privacy" },
  { label: "Terms", href: "/terms" },
];
---

<footer class="relative overflow-hidden bg-ink-950 text-white">
  <div aria-hidden="true" class="pointer-events-none absolute -top-32 left-1/2 -translate-x-1/2 size-[600px] rounded-full bg-brand-600/30 blur-[120px]"></div>
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 grid-pattern opacity-30"></div>

  <div class="container-page relative pt-20 md:pt-24">
    <div class="grid grid-cols-2 md:grid-cols-12 gap-10 md:gap-8 pb-14">
      <div class="col-span-2 md:col-span-5">
        <a href="/" class="inline-flex items-center gap-2" aria-label={`${SITE.name} home`}>
          <Image src={logoLight} alt={SITE.name} width={230} height={40} densities={[1, 2, 3]} class="h-10 w-auto" />
        </a>
        <p class="mt-5 text-white/70 max-w-sm leading-relaxed">{SITE.description}</p>
        <ul class="mt-6 space-y-2 text-white/60 text-sm">
          <li class="flex items-start gap-3">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="size-4 mt-0.5 text-brand-400 shrink-0">
              <path d="M12 21s-7-7-7-12a7 7 0 1114 0c0 5-7 12-7 12z" stroke-linecap="round" stroke-linejoin="round" />
              <circle cx="12" cy="9" r="2.5" />
            </svg>
            {SITE.address}
          </li>
          <li class="flex items-start gap-3">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="size-4 mt-0.5 text-brand-400 shrink-0">
              <path d="M22 16.92V21a1 1 0 01-1.09 1A19 19 0 012 4.09 1 1 0 013 3h4.09a1 1 0 011 .75l1 4a1 1 0 01-.27 1L7 10a16 16 0 007 7l1.25-1.82a1 1 0 011-.27l4 1a1 1 0 01.75 1V21" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <a href={`tel:${SITE.phone.replace(/\s|\(|\)|-/g, "")}`} class="hover:text-white">{SITE.phone}</a>
          </li>
          <li class="flex items-start gap-3">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="size-4 mt-0.5 text-brand-400 shrink-0">
              <rect x="3" y="5" width="18" height="14" rx="2" />
              <path d="M3 7l9 6 9-6" />
            </svg>
            <a href={`mailto:${SITE.email}`} class="hover:text-white">{SITE.email}</a>
          </li>
        </ul>
      </div>

      <div class="md:col-span-3 md:col-start-7">
        <h4 class="text-white font-semibold mb-5 text-sm uppercase tracking-widest">Learn</h4>
        <ul class="space-y-3 text-white/70">
          {learn.map((l) => (
            <li>
              <a href={l.href} class="hover:text-white transition-colors inline-flex items-center gap-1.5 group">
                {l.label}
                <span class="opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all text-brand-400">→</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-3">
        <h4 class="text-white font-semibold mb-5 text-sm uppercase tracking-widest">Company</h4>
        <ul class="space-y-3 text-white/70">
          {company.map((l) => (
            <li>
              <a href={l.href} class="hover:text-white transition-colors inline-flex items-center gap-1.5 group">
                {l.label}
                <span class="opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all text-brand-400">→</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 py-6 border-t border-white/10 text-sm">
      <p class="text-white/50">© {year} {SITE.name}. All rights reserved.</p>
      <div class="flex items-center gap-2">
        <a href={SITE.social.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="grid place-items-center size-10 rounded-xl bg-white/5 hover:bg-brand-600 transition-colors">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="size-4">
            <rect x="3" y="3" width="18" height="18" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="0.6" fill="currentColor" />
          </svg>
        </a>
        <a href={SITE.social.youtube} target="_blank" rel="noopener" aria-label="YouTube" class="grid place-items-center size-10 rounded-xl bg-white/5 hover:bg-brand-600 transition-colors">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="size-4">
            <path d="M22 8s-.2-1.6-.8-2.3c-.7-.9-1.6-.9-2-1C16 4.5 12 4.5 12 4.5s-4 0-7.2.2c-.4.1-1.3.1-2 1C2.2 6.4 2 8 2 8S1.8 9.9 1.8 11.7v1.3C1.8 14.8 2 16.7 2 16.7s.2 1.6.8 2.3c.7.9 1.7.9 2.1 1 1.5.2 6.6.2 6.6.2s4 0 7.2-.2c.4-.1 1.3-.1 2-1 .6-.7.8-2.3.8-2.3s.2-1.9.2-3.7v-1.3C22.2 9.9 22 8 22 8z" />
            <path d="M10 15V9l5 3-5 3z" fill="currentColor" />
          </svg>
        </a>
        <a href={SITE.social.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn" class="grid place-items-center size-10 rounded-xl bg-white/5 hover:bg-brand-600 transition-colors">
          <svg viewBox="0 0 24 24" fill="currentColor" class="size-4">
            <path d="M4.98 3.5a2.5 2.5 0 11-.02 5.001A2.5 2.5 0 014.98 3.5zM3 9h4v12H3V9zm7 0h3.8v1.7h.05c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.4c0-1.3-.02-2.97-1.8-2.97-1.8 0-2.08 1.4-2.08 2.87V21h-4V9z" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
