---
import Container from "~/components/ui/Container.astro";
import Section from "~/components/ui/Section.astro";
import { COURSES } from "~/data/courses";

const featured = COURSES.slice(0, 3);
---
<Section id="courses" size="lg" bg="white">
  <Container>
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
      <div class="max-w-2xl">
        <div class="anim-on-scroll inline-flex items-center gap-2 px-3 py-1 mb-5 text-xs font-semibold tracking-[0.18em] uppercase rounded-full bg-brand-50 text-brand-700 border border-brand-100">
          <span class="size-1.5 rounded-full bg-current"></span>
          Curriculum
        </div>
        <h2 class="anim-on-scroll delay-1 text-balance text-3xl sm:text-4xl md:text-5xl font-display font-bold leading-[1.05] tracking-tight">
          Tracks built around <span class="gradient-text">real shifts</span>.
        </h2>
        <p class="anim-on-scroll delay-2 mt-4 text-ink-500 text-lg leading-relaxed">
          Bite-sized lessons. Field-tested techniques. Replayable demos.
        </p>
      </div>
      <a href="/courses" class="anim-on-scroll delay-3 inline-flex items-center gap-2 text-brand-700 font-semibold hover:gap-3 transition-all">
        See all courses
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" class="size-4"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

    <div class="mt-14 grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {featured.map((c, i) => (
        <a
          href="/courses"
          class="anim-on-scroll group relative flex flex-col rounded-3xl bg-white p-6 ring-1 ring-ink-100 hover:ring-brand-200 hover:shadow-xl hover:-translate-y-1 transition-all duration-500 overflow-hidden"
          style={`transition-delay: ${i * 90}ms`}
        >
          <div aria-hidden="true" class="absolute -top-16 -right-16 size-40 rounded-full bg-brand-100/0 group-hover:bg-brand-100 transition-colors duration-500"></div>

          <div class="relative">
            <div class="flex items-center gap-2 text-xs">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full bg-brand-50 text-brand-700 font-semibold uppercase tracking-wider text-[10px]">{c.category}</span>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full bg-ink-100 text-ink-600 font-semibold uppercase tracking-wider text-[10px]">{c.level}</span>
            </div>
            <h3 class="mt-5 text-xl font-display font-bold leading-snug text-ink-900 group-hover:text-brand-700 transition-colors">{c.title}</h3>
            <p class="mt-3 text-sm text-ink-500 leading-relaxed">{c.description}</p>
          </div>

          <div class="relative mt-6 pt-5 border-t border-ink-100 flex items-center justify-between text-sm text-ink-500">
            <div class="flex items-center gap-3">
              <span class="inline-flex items-center gap-1.5">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="size-4">
                  <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
                {c.duration}
              </span>
              <span class="inline-flex items-center gap-1.5">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="size-4">
                  <polygon points="6,4 20,12 6,20" fill="currentColor" stroke-linejoin="round"/>
                </svg>
                {c.lessons} lessons
              </span>
            </div>
            <span class="text-brand-700 font-semibold transition-transform group-hover:translate-x-1">→</span>
          </div>
        </a>
      ))}
    </div>
  </Container>
</Section>
